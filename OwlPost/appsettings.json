{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RabbitMQ": {
    "Connection": {
      "HostName": "localhost",
      "UserName": "guest",
      "Password": "guest",
      "Port": 5672
    },
    "ChannelOption": {
      "PublisherConfirmationsEnabled": true,
      "PublisherConfirmationTrackingEnabled": true,
      "ContinuationTimeout": "00:00:30",
      "PrefetchCount": 10,
      "PrefetchSize": 0
    }
  },
  "RateLimiting": {
    "DefaultPolicy": "Read",
    "Policies": {
      "Read": {
        "TokenLimit": 200,
        "TokensPerPeriod": 50,
        "ReplenishmentPeriod": "00:00:10",
        "QueueLimit": 0,
        "QueueProcessingOrder": "OldestFirst",
        "AutoReplenishment": true
      },
      "Write": {
        "TokenLimit": 20,
        "TokensPerPeriod": 5,
        "ReplenishmentPeriod": "00:00:10",
        "QueueLimit": 0,
        "QueueProcessingOrder": "OldestFirst",
        "AutoReplenishment": true
      },
      "Authentication": {
        "TokenLimit": 5,
        "TokensPerPeriod": 1,
        "ReplenishmentPeriod": "00:01:00",
        "QueueLimit": 0,
        "QueueProcessingOrder": "OldestFirst",
        "AutoReplenishment": true
      },
      "Admin": {
        "TokenLimit": 500,
        "TokensPerPeriod": 100,
        "ReplenishmentPeriod": "00:00:10"
      },
      "Upload": {
        "TokenLimit": 3,
        "TokensPerPeriod": 1,
        "ReplenishmentPeriod": "00:00:30",
        "QueueLimit": 2
      }
    }
  }

}
