{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RabbitMQ": {
    "Connection": {
      "HostName": "localhost",
      "UserName": "guest",
      "Password": "guest",
      "Port": 5672
    },
    "ChannelOption": {
      "PublisherConfirmationsEnabled": true,
      "PublisherConfirmationTrackingEnabled": true,
      "ContinuationTimeout": "00:00:30",
      "PrefetchCount": 10,
      "PrefetchSize": 0
    }
  },
  "RateLimiting": {
    "TokenBucket": {
      "Enabled": true,
      "TokenLimit": 200,
      "TokensPerPeriod": 50,
      "ReplenishmentPeriod": "00:00:10",
      "QueueLimit": 0,
      "QueueProcessingOrder": "OldestFirst",
      "AutoReplenishment": true
    }
  }

}
