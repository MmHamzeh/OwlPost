{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RabbitMQ": {
    "Connection": {
      "HostName": "localhost",
      "UserName": "guest",
      "Password": "guest",
      "Port": 5672
    },
    "Exchanges": [
      {
        "Name": "chat.exchange",
        "ExchangeTypeEnm": "Direct",
        "Durable": true,
        "AutoDelete": false
      },
      {
        "Name": "notification.exchange",
        "ExchangeTypeEnm": "Fanout",
        "Durable": false,
        "AutoDelete": false
      }
    ],
    "Queues": [
      {
        "Name": "chat.queue",
        "Durable": true,
        "Exclusive": false,
        "AutoDelete": false
      },
      {
        "Name": "notification.queue",
        "Durable": false,
        "Exclusive": false,
        "AutoDelete": false
      }
    ],
    "ChannelOption": {
      "PublisherConfirmationsEnabled": true,
      "PublisherConfirmationTrackingEnabled": true,
      "ContinuationTimeout": "00:00:30"
    }
  }

}
